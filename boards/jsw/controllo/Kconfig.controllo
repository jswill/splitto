config BOARD_CONTROLLO
    select SOC_NRF52840_QIAA
    select ZMK_BOARD_COMPAT if BOARD_CONTROLLO_NRF52840_ZMK
    imply RETAINED_MEM if BOARD_CONTROLLO_NRF52840_ZMK
    imply RETENTION if BOARD_CONTROLLO_NRF52840_ZMK
    imply RETENTION_BOOT_MODE if BOARD_CONTROLLO_NRF52840_ZMK
    
config BOARD_ENABLE_DCDC
    bool "Enable DCDC mode"
    select SOC_DCDC_NRF52X
    default y
    depends on BOARD_CONTROLLO